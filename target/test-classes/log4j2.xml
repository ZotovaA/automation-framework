<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <File name="fileAppender" fileName="logfile.log">
            <PatternLayout pattern="%d %-5p [%c{1}] %m%n"/>
        </File>
    </Appenders>
    <Loggers>
        <Root level="INFO">
            <AppenderRef ref="fileAppender"/>
        </Root>
    </Loggers>
</Configuration>